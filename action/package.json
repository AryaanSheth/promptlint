{
  "name": "promptlint-action",
  "version": "1.0.0",
  "description": "GitHub Action: lint LLM prompts for injection attacks, leaked secrets, PII, token waste, and quality issues",
  "private": true,
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify --source-map --license licenses.txt",
    "build:dev": "ncc build src/index.ts -o dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/glob": "^0.4.0",
    "promptlint-cli": "file:../npm"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.4.0"
  }
}
