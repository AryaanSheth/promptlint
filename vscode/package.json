{
  "name": "promptlint-vscode",
  "displayName": "PromptLint",
  "description": "VS Code extension that runs the promptlint CLI to provide diagnostics and fixes for LLM prompts.",
  "version": "1.0.0",
  "publisher": "PromptLint",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AryaanSheth/promptlint"
  },
  "keywords": ["prompt", "llm", "linting", "ai", "gpt", "claude", "gemini", "openai"],
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.js",
  "categories": ["Linters"],
  "activationEvents": [
    "onLanguage:plaintext",
    "onLanguage:markdown",
    "onLanguage:python",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:json",
    "onLanguage:yaml"
  ],
  "contributes": {
    "languages": [
      { "id": "plaintext", "aliases": ["Plain Text"], "extensions": [".txt"] },
      { "id": "markdown", "aliases": ["Markdown"], "extensions": [".md"] }
    ],
    "commands": [
      { "command": "promptlint.lint", "title": "PromptLint: Lint File" },
      { "command": "promptlint.fix", "title": "PromptLint: Fix File" },
      { "command": "promptlint.fixAll", "title": "PromptLint: Fix All Files" },
      { "command": "promptlint.dashboard", "title": "PromptLint: Show Dashboard" },
      { "command": "promptlint.explainRule", "title": "PromptLint: Explain Rule" },
      { "command": "promptlint.init", "title": "PromptLint: Initialize Config" }
    ],
    "configuration": {
      "type": "object",
      "title": "PromptLint",
      "properties": {
        "promptlint.lintOnSave": { "type": "boolean", "default": true, "description": "Lint on save" },
        "promptlint.lintOnType": { "type": "boolean", "default": false, "description": "Lint on type (debounced)" },
        "promptlint.lintOnTypeDelay": { "type": "number", "default": 500, "description": "Debounce delay in ms" },
        "promptlint.languages": { "type": "array", "items": { "type": "string" }, "default": ["plaintext","markdown","python","javascript","typescript","json","yaml","toml"], "description": "Languages to lint" },
        "promptlint.configPath": { "type": "string", "default": "", "description": "Path to .promptlintrc" },
        "promptlint.failLevel": { "type": "string", "enum": ["none","warn","critical"], "default": "critical", "description": "Fail level threshold" },
        "promptlint.showStatusBar": { "type": "boolean", "default": true, "description": "Show status bar with token/cost" }
      }
    }
  },
  "dependencies": {
    "promptlint-cli": "file:../npm",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^18.14.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.4"
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -w -p ./tsconfig.json"
  }
}
